{
  "apps": [
    {
      "name": "telegram-bot",
      "script": "bot.py",
      "interpreter": "./venv/Scripts/python.exe",
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 5000,
      "log_date_format": "YYYY-MM-DD HH:mm:ss",
      "out_file": "logs/out.log",
      "error_file": "logs/error.log",
      "merge_logs": true,
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      }
    }
  ]
}